# ai/ — FastAPI training server config (read by pydantic-settings)

# SQLAlchemy async URL. SQLite for the MVP; the file lives at ai/playground.db.
DATABASE_URL=sqlite+aiosqlite:///./playground.db

# JWT signing secret. CHANGE THIS in any real deployment.
AUTH_SECRET=change-me-to-a-long-random-string
TOKEN_TTL_SECONDS=43200

# Where per-run trained-model checkpoints are written.
WORK_DIR=./.runs

# Seed the classroom logins (group8..group16) on startup.
SEED_USERS=true
SEED_PASSWORD=trainllmwithucf

# Browser origins allowed to call ai directly (comma-separated).
CORS_ORIGINS=https://llm.ragsof.dev,http://localhost:3000
